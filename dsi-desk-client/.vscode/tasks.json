{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build nds",
      "type": "shell",
      "command": "make",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "make clean"
    },
    {
      "label": "run",
      "type": "shell",
      "command": "melonDS ${workspaceFolderBasename}.nds",
      "problemMatcher": []
    }
  ]
}
